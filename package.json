{
  "name": "orion",
  "productName": "Orion",
  "description": "My Electron application description",
  "keywords": [],
  "main": "./.build/main.cjs",
  "version": "1.1.0",
  "author": "kenokayasu",
  "license": "GPL-3.0",
  "scripts": {
    "build:runtime": "node scripts/build-runtime.js",
    "start": "npm run build:runtime && node scripts/run-electron.js .",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "test:electron": "npm run build:runtime && node --test --test-concurrency=1 test/electron/*.test.js",
    "perf:electron": "npm run build:runtime && node scripts/perf.js",
    "perf:swift": "bash SwiftUIApp/script/perf.sh",
    "perf": "npm run perf:electron && npm run perf:swift",
    "pack": "npm run build:runtime && electron-builder --dir",
    "dist": "npm run build:runtime && electron-builder",
    "dist:mac": "npm run build:runtime && electron-builder --mac",
    "dist:win": "npm run build:runtime && electron-builder --win --x64 --arm64"
  },
  "build": {
    "appId": "com.orion.browser",
    "productName": "Orion",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "assets/orion.ico",
        "to": "assets/orion.ico"
      },
      {
        "from": "assets/orion-mac.png",
        "to": "assets/orion-mac.png"
      }
    ],
    "mac": {
      "icon": "assets/orion.icns",
      "category": "public.app-category.productivity",
      "timestamp": "none",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "assets/orion.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "buildUniversalInstaller": false,
      "artifactName": "${productName} Setup ${version} ${arch}.${ext}"
    },
    "portable": {
      "buildUniversalInstaller": false,
      "artifactName": "${productName} ${version} ${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pika04568-sys",
        "repo": "orion",
        "releaseType": "release"
      }
    ],
    "compression": "maximum",
    "asar": {
      "ordering": "scripts/asar-ordering.txt"
    },
    "files": [
      ".build/**",
      "package.json",
      "node_modules/electron-chrome-extensions/**",
      "node_modules/electron-chrome-web-store/**",
      "node_modules/electron-updater/**"
    ]
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.6",
    "playwright-core": "^1.55.0"
  },
  "dependencies": {
    "electron-chrome-extensions": "4.9.0",
    "electron-chrome-web-store": "0.13.0",
    "electron-updater": "^6.8.9"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "esbuild@0.25.12": true,
    "electron-winstaller@5.4.0": true
  }
}
