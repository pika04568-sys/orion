{
  "name": "orion",
  "productName": "Orion",
  "description": "My Electron application description",
  "keywords": [],
  "main": "./main.js",
  "version": "1.1.0",
  "author": "kenokayasu",
  "license": "GPL-3.0",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64 --arm64"
  },
  "build": {
    "appId": "com.orion.browser",
    "productName": "Orion",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "assets/orion.ico",
        "to": "assets/orion.ico"
      },
      {
        "from": "assets/orion-mac.png",
        "to": "assets/orion-mac.png"
      }
    ],
    "mac": {
      "icon": "assets/orion.icns",
      "category": "public.app-category.productivity",
      "timestamp": "none",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "assets/orion.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "buildUniversalInstaller": false,
      "artifactName": "${productName} Setup ${version} ${arch}.${ext}"
    },
    "portable": {
      "buildUniversalInstaller": false,
      "artifactName": "${productName} ${version} ${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pika04568-sys",
        "repo": "orion",
        "releaseType": "release"
      }
    ],
    "compression": "maximum",
    "files": [
      "adblock.js",
      "app-utils.js",
      "browser-privacy.js",
      "browser-security.js",
      "extensions.js",
      "extension-manager.js",
      "localization.js",
      "ai-summary.js",
      "main-tab-state.js",
      "main.js",
      "offline.js",
      "renderer.js",
      "preload.js",
      "index.html",
      "newtab.html",
      "newtab.js",
      "offline.html",
      "extensions.html",
      "package.json",
      "offline-arcade.js",
      "offline-game-helpers.js",
      "reader-session.js",
      "reader-utils.js",
      "tab-groups.js",
      "reader.html",
      "reader.js",
      "node_modules/electron-chrome-extensions/**",
      "node_modules/electron-chrome-web-store/**"
    ]
  },
  "devDependencies": {
    "electron": "39.1.2",
    "electron-builder": "^26.4.0"
  },
  "dependencies": {
    "electron-chrome-extensions": "4.9.0",
    "electron-chrome-web-store": "0.13.0",
    "electron-updater": "^6.8.3",
    "update-electron-app": "^3.1.2"
  }
}
